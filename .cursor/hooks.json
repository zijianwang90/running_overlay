{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/project-log-reminder.py",
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/project-log-reminder.py",
        "matcher": "Write|StrReplace",
        "timeout": 5
      }
    ]
  }
}
