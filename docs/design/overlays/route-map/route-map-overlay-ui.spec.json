{
  "name": "Route Map Overlay UI",
  "updated": "2026-04-28 (shared stats bar + shared layout renderer alignment)",
  "references": {
    "designDoc": "./route-map-overlay-ui.md",
    "moduleDoc": "../../../overlay-modules/route-map-overlay.md",
    "fullVideoMockup": null,
    "relatedInspectorSpec": "../../panels/inspector/inspector-ui.md",
    "relatedNumericSpec": "../numeric/numeric-overlay-ui.spec.json",
    "relatedStyleSpec": "../../system/app-ui.md"
  },
  "appliesToOverlayTypes": [
    "routeMap"
  ],
  "excludedOverlayTypes": [
    "heartRate",
    "pace",
    "calories",
    "elapsedTime",
    "realTime",
    "distance",
    "elevation",
    "cadence",
    "power",
    "distanceTimeline",
    "elevationChart",
    "runningGauge"
  ],
  "intent": {
    "template": "dense Inspector detail panel for the Route Map composite overlay",
    "density": "matches numeric-overlay-ui density tokens; reuses InspectorDense* components",
    "avoid": [
      "fixed pace color bar or legacy gradient-band legend in the Status Bar",
      "single hard-coded layout that mixes container and route style",
      "large card rows or loose vertical spacing",
      "duplicating Numeric Overlay primitives",
      "exposing controls without a model field"
    ]
  },
  "tokens": {
    "reuseFrom": "../numeric/numeric-overlay-ui.spec.json",
    "numeric": {
      "sectionHeaderHeight": 30,
      "rowHeight": 32,
      "rowGap": 6,
      "sectionGap": 8,
      "labelColumnWidth": 88,
      "controlHeight": 28,
      "iconButtonSize": 28,
      "swatchSize": 20,
      "panelPaddingX": 12,
      "panelPaddingY": 8,
      "controlRadius": 5
    }
  },
  "header": {
    "title": "Route Map",
    "pill": "Overlay",
    "subtitle": "{activity.totalDistance}",
    "icon": "map",
    "iconTint": "accentBlue",
    "actions": [
      "back",
      "delete"
    ]
  },
  "sections": [
    {
      "id": "preset",
      "title": "Preset",
      "icon": "wand.and.stars",
      "controls": [
        {
          "id": "routeStylePreset",
          "type": "dropdown",
          "modelPath": "OverlayStyle.routeMapPreset",
          "options": [
            "minimal",
            "gradient",
            "glow"
          ],
          "modelBacked": true,
          "notes": [
            "Describes the polyline appearance only.",
            "No longer encodes 'show map' — that toggle lives on the Background Map section header.",
            "Legacy 'mapKit' value is migrated to 'gradient' on decode."
          ]
        },
        {
          "id": "distanceReadout",
          "type": "readout",
          "modelPath": "ActivityTimeline.distanceMeters",
          "displayRule": "{distance / 1000 with 2 decimals} km, '—' when zero"
        }
      ],
      "removedControls": [
        {
          "id": "containerPreset",
          "removedAt": "2026-04-27",
          "reason": "Conflicted with the Container section's individual controls. Still callable via ProjectDocument.setOverlayRouteMapContainerPreset for templates and tests."
        }
      ]
    },
    {
      "id": "layout",
      "title": "Layout",
      "icon": "scope",
      "controls": [
        {
          "id": "position",
          "type": "numberPair",
          "labels": [
            "X",
            "Y"
          ],
          "modelPaths": [
            "OverlayElement.position.x",
            "OverlayElement.position.y"
          ]
        },
        {
          "id": "scale",
          "type": "slider",
          "modelPath": "OverlayElement.scale"
        },
        {
          "id": "rotation",
          "type": "slider",
          "modelPath": "OverlayStyle.rotationDegrees",
          "deprecated": true,
          "notes": [
            "Shared Layout section has removed Rotation.",
            "Use shared Layout rows: Position / Scale / Width / Height / Opacity."
          ]
        },
        {
          "id": "containerOpacity",
          "type": "slider",
          "modelPath": "OverlayStyle.backgroundOpacity"
        }
      ]
    },
    {
      "id": "container",
      "title": "Container",
      "icon": "rectangle.dashed",
      "controls": [
        {
          "id": "shape",
          "type": "segmented",
          "options": [
            "square",
            "circle"
          ],
          "modelPath": "OverlayStyle.routeMapShape",
          "notes": [
            "Picking circle collapses width and height to the shorter edge so editor handles stay synced with the rendered diameter."
          ]
        },
        {
          "id": "width",
          "type": "slider",
          "range": [
            120,
            720
          ],
          "step": 4,
          "modelPath": "OverlayStyle.routeMapWidth",
          "modelBacked": true,
          "visibleWhen": "shape == square",
          "displayRule": "NN pt"
        },
        {
          "id": "height",
          "type": "slider",
          "range": [
            120,
            720
          ],
          "step": 4,
          "modelPath": "OverlayStyle.routeMapHeight",
          "modelBacked": true,
          "visibleWhen": "shape == square",
          "displayRule": "NN pt"
        },
        {
          "id": "size",
          "type": "slider",
          "range": [
            120,
            600
          ],
          "step": 4,
          "modelPath": "min(OverlayStyle.routeMapWidth, OverlayStyle.routeMapHeight)",
          "writes": [
            "OverlayStyle.routeMapWidth",
            "OverlayStyle.routeMapHeight"
          ],
          "modelBacked": true,
          "visibleWhen": "shape == circle",
          "displayRule": "NN pt"
        }
      ],
      "removedControls": [
        {
          "id": "cornerRadius",
          "removedAt": "2026-06-16",
          "replacement": "Shared Background Radius",
          "modelPath": "OverlayStyle.backgroundRadius"
        },
        {
          "id": "edgeMode",
          "removedAt": "2026-06-16",
          "replacement": "Shared Effects Fade Out",
          "modelPath": "OverlayStyle.backgroundFadeOutEnabled"
        },
        {
          "id": "edgeSoftness",
          "removedAt": "2026-06-16",
          "replacement": "Shared Effects Fade Amount",
          "modelPath": "OverlayStyle.backgroundFadeOutAmount"
        },
        {
          "id": "border",
          "removedAt": "2026-06-16",
          "replacement": "Shared Border module",
          "modelPath": "OverlayStyle.borderEnabled / borderColor / borderOpacity / borderWidth"
        }
      ]
    },
    {
      "id": "backgroundMap",
      "title": "Background Map",
      "icon": "map",
      "accessory": {
        "id": "showMap",
        "type": "toggle",
        "modelPath": "OverlayStyle.routeMapBackgroundStyle != .none",
        "writes": [
          "OverlayStyle.routeMapBackgroundStyle"
        ],
        "setter": "ProjectDocument.setOverlayRouteMapShowMap",
        "rules": [
          "Off → routeMapBackgroundStyle = .none.",
          "On → restore previously selected style, defaulting to .dark when previous value was .none."
        ]
      },
      "controls": [
        {
          "id": "mapStyle",
          "type": "dropdown",
          "options": [
            "dark",
            "light",
            "terrain",
            "satellite"
          ],
          "modelPath": "OverlayStyle.routeMapBackgroundStyle",
          "modelBacked": true,
          "enabledWhen": "showMap == true",
          "notes": [
            "Excludes 'none' — show / hide is handled by the showMap toggle accessory."
          ]
        },
        {
          "id": "mapOpacity",
          "type": "slider",
          "range": [
            0.0,
            1.0
          ],
          "modelPath": "OverlayStyle.routeMapMapOpacity",
          "modelBacked": true,
          "enabledWhen": "showMap == true"
        },
        {
          "id": "contrast",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "saturation",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "brightness",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "blur",
          "type": "slider",
          "modelBacked": "phaseF"
        }
      ]
    },
    {
      "id": "routeLine",
      "title": "Route Line",
      "icon": "scribble.variable",
      "controls": [
        {
          "id": "colorMode",
          "type": "segmented",
          "options": [
            "solid",
            "gradient"
          ],
          "modelPath": "OverlayStyle.routeMapColorMode"
        },
        {
          "id": "solidColor",
          "type": "swatches",
          "modelPath": "OverlayStyle.foregroundColor",
          "visibleWhen": "colorMode == solid"
        },
        {
          "id": "gradientStart",
          "type": "swatches",
          "modelPath": "OverlayStyle.routeMapGradientStart",
          "visibleWhen": "colorMode == gradient"
        },
        {
          "id": "gradientMid",
          "type": "swatches",
          "modelPath": "OverlayStyle.routeMapGradientMiddle",
          "visibleWhen": "colorMode == gradient"
        },
        {
          "id": "gradientEnd",
          "type": "swatches",
          "modelPath": "OverlayStyle.routeMapGradientEnd",
          "visibleWhen": "colorMode == gradient"
        },
        {
          "id": "gradientMetric",
          "type": "dropdown",
          "options": [
            "pace",
            "heartRate",
            "power",
            "elevation"
          ],
          "modelBacked": "phaseF"
        },
        {
          "id": "width",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "opacity",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "dash",
          "type": "toggleAndPattern",
          "modelBacked": "phaseF"
        },
        {
          "id": "glow",
          "type": "toggleAndSliders",
          "modelBacked": "phaseF"
        },
        {
          "id": "shadow",
          "type": "toggleAndSliders",
          "modelBacked": "phaseF"
        }
      ]
    },
    {
      "id": "markers",
      "title": "Markers",
      "icon": "mappin.and.ellipse",
      "controls": [
        {
          "id": "startMarker",
          "type": "toggle",
          "options": [
            "hidden",
            "dot"
          ],
          "modelPath": "OverlayStyle.routeMapStartMarkerStyle"
        },
        {
          "id": "finishMarker",
          "type": "toggle",
          "options": [
            "hidden",
            "dot"
          ],
          "modelPath": "OverlayStyle.routeMapEndMarkerStyle"
        },
        {
          "id": "startColor",
          "type": "swatches",
          "modelPath": "OverlayStyle.routeMapStartMarkerColor"
        },
        {
          "id": "finishColor",
          "type": "swatches",
          "specialFirstPreset": "checkerboard3x3",
          "default": "checkerboard3x3",
          "modelPath": "OverlayStyle.routeMapEndMarkerColor"
        },
        {
          "id": "movingMarker",
          "type": "toggle",
          "options": [
            "hidden",
            "dot"
          ],
          "modelPath": "OverlayStyle.routeMapRunnerMarkerStyle"
        },
        {
          "id": "movingColor",
          "type": "swatches",
          "modelPath": "OverlayStyle.routeMapRunnerDotColor"
        },
        {
          "id": "markerSize",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "markerBorder",
          "type": "toggleAndSliders",
          "modelBacked": "phaseF"
        },
        {
          "id": "markerLabel",
          "type": "toggleAndText",
          "modelBacked": "phaseF"
        }
      ]
    },
    {
      "id": "statusBar",
      "title": "Status Bar",
      "icon": "tablecells",
      "accessory": {
        "id": "statusBarEnabled",
        "type": "toggle",
        "modelPath": "OverlayStyle.routeMapStatsBar.visible",
        "placement": "headerLeftOfChevron"
      },
      "controls": [
        {
          "id": "placement",
          "type": "dropdown",
          "modelPath": "OverlayStyle.routeMapStatsBar.placement",
          "options": [
            "topAttached",
            "bottomAttached",
            "leftAttached",
            "rightAttached",
            "insideTop",
            "insideBottom"
          ]
        },
        {
          "id": "inside",
          "type": "toggle",
          "modelPath": "OverlayStyle.routeMapStatsBar.inside"
        },
        {
          "id": "size",
          "type": "slider",
          "range": [
            32,
            120
          ],
          "modelPath": "OverlayStyle.routeMapStatsBar.height"
        },
        {
          "id": "width",
          "type": "slider",
          "range": [
            0,
            640
          ],
          "modelPath": "OverlayStyle.routeMapStatsBar.width",
          "displayRule": "0 => Auto"
        },
        {
          "id": "offset",
          "type": "numberPair",
          "labels": [
            "X",
            "Y"
          ],
          "modelPaths": [
            "OverlayStyle.routeMapStatsBar.offsetX",
            "OverlayStyle.routeMapStatsBar.offsetY"
          ]
        },
        {
          "id": "itemGap",
          "type": "slider",
          "range": [
            0,
            32
          ],
          "modelPath": "OverlayStyle.routeMapStatsBar.itemSpacing"
        },
        {
          "id": "padding",
          "type": "numberPair",
          "labels": [
            "X",
            "Y"
          ],
          "ranges": [
            [
              4,
              24
            ],
            [
              2,
              16
            ]
          ],
          "defaults": [
            10,
            6
          ],
          "modelPaths": [
            "OverlayStyle.routeMapStatusBarPaddingX",
            "OverlayStyle.routeMapStatusBarPaddingY"
          ],
          "modelBacked": "phaseF"
        },
        {
          "id": "slotCount",
          "type": "segmented",
          "options": [
            1,
            2,
            3,
            4
          ],
          "default": 3,
          "modelPath": "OverlayStyle.routeMapStatusBarSlotCount",
          "modelBacked": "phaseF"
        },
        {
          "id": "slotLayout",
          "type": "segmented",
          "options": [
            "equalColumns",
            "primaryLeft",
            "primaryCenter",
            "compactBadges"
          ],
          "default": "equalColumns",
          "modelPath": "OverlayStyle.routeMapStatusBarLayout",
          "modelBacked": "phaseF"
        },
        {
          "id": "alignment",
          "type": "segmented",
          "options": [
            "leading",
            "center",
            "trailing"
          ],
          "default": "center",
          "modelPath": "OverlayStyle.routeMapStatusBarAlignment",
          "modelBacked": "phaseF"
        },
        {
          "id": "dividers",
          "type": "toggleAndSliders",
          "modelPaths": [
            "OverlayStyle.routeMapStatusBarDividerVisible",
            "OverlayStyle.routeMapStatusBarDividerColor",
            "OverlayStyle.routeMapStatusBarDividerOpacity",
            "OverlayStyle.routeMapStatusBarDividerWidth"
          ],
          "defaults": {
            "visible": true,
            "opacity": 0.28,
            "width": 1.0
          },
          "modelBacked": "phaseF"
        },
        {
          "id": "slots",
          "type": "list",
          "itemModel": "RouteMapStatusBarSlotConfig",
          "itemCountRange": [
            1,
            4
          ],
          "defaultItems": [
            {
              "metric": "distance",
              "label": "DISTANCE",
              "enabled": true
            },
            {
              "metric": "pace",
              "label": "PACE",
              "enabled": true
            },
            {
              "metric": "elapsedTime",
              "label": "TIME",
              "enabled": true
            },
            {
              "metric": "heartRate",
              "label": "HR",
              "enabled": false
            }
          ],
          "metricOptions": [
            "distance",
            "pace",
            "elapsedTime",
            "heartRate",
            "power",
            "cadence",
            "elevation",
            "calories",
            "currentTime",
            "remainingDistance",
            "progressPercent",
            "customText"
          ],
          "perItemControls": [
            "enabled",
            "metric",
            "labelOverride",
            "unitMode",
            "customUnit",
            "iconEnabled",
            "iconName",
            "iconColor",
            "valueColorOverride",
            "labelColorOverride",
            "widthWeight"
          ],
          "modelBacked": "phaseF"
        },
        {
          "id": "typography",
          "type": "group",
          "modelBacked": "phaseF",
          "controls": [
            "fontFamily",
            "valueSize",
            "valueWeight",
            "labelSize",
            "labelWeight",
            "unitSize",
            "valueOpacity",
            "labelOpacity",
            "unitOpacity",
            "monospacedDigits"
          ]
        }
      ],
      "migrationNotes": [
        "Map legacy routeMapLegendVisible to routeMapStatsBar.visible on decode.",
        "Do not expose legacy routeMapLegendMode gradientBand in new UI.",
        "Route Map and Distance Timeline share the same full Stats Bar control surface and renderer behavior."
      ]
    },
    {
      "id": "effects",
      "title": "Effects",
      "icon": "sparkles",
      "controls": [
        {
          "id": "shadowOpacity",
          "type": "slider",
          "modelPath": "OverlayStyle.shadowOpacity"
        },
        {
          "id": "shadowRadius",
          "type": "slider",
          "modelPath": "OverlayStyle.shadowRadius"
        },
        {
          "id": "shadowOffset",
          "type": "numberPair",
          "modelPaths": [
            "OverlayStyle.shadowOffsetX",
            "OverlayStyle.shadowOffsetY"
          ]
        },
        {
          "id": "shadowColor",
          "type": "swatches",
          "modelBacked": "phaseF"
        },
        {
          "id": "glowEnabled",
          "type": "toggle",
          "modelBacked": "phaseF"
        },
        {
          "id": "glowColor",
          "type": "swatches",
          "modelBacked": "phaseF"
        },
        {
          "id": "glowOpacity",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "glowRadius",
          "type": "slider",
          "modelBacked": "phaseF"
        },
        {
          "id": "blendMode",
          "type": "dropdown",
          "modelBacked": "phaseF"
        },
        {
          "id": "containerFillOpacity",
          "type": "slider",
          "modelPath": "OverlayStyle.backgroundOpacity"
        }
      ]
    }
  ],
  "containerPresetDefaults": {
    "squareHardEdge": {
      "shape": "square",
      "edgeFade": "solid",
      "fadeAmount": 0.0,
      "mapOpacity": 0.72,
      "borderEnabled": true,
      "borderOpacity": 0.22,
      "borderWidth": 1.0,
      "shadowEnabled": true,
      "shadowOpacity": 0.35,
      "shadowRadius": 14,
      "shadowOffsetX": 0,
      "shadowOffsetY": 6
    },
    "circleHardEdge": {
      "shape": "circle",
      "edgeFade": "solid",
      "fadeAmount": 0.0,
      "mapOpacity": 0.72,
      "borderEnabled": true,
      "borderOpacity": 0.24,
      "borderWidth": 1.2,
      "shadowEnabled": true,
      "shadowOpacity": 0.38,
      "shadowRadius": 16,
      "shadowOffsetX": 0,
      "shadowOffsetY": 6
    },
    "squareGradientEdge": {
      "shape": "square",
      "edgeFade": "fadeOut",
      "fadeAmount": 0.3,
      "mapOpacity": 0.58,
      "borderEnabled": false,
      "shadowEnabled": false
    },
    "circleGradientEdge": {
      "shape": "circle",
      "edgeFade": "fadeOut",
      "fadeAmount": 0.34,
      "mapOpacity": 0.58,
      "borderEnabled": false,
      "shadowEnabled": false
    }
  },
  "modelBackedToday": [
    "routeMapPreset (line aesthetic only — no longer encodes 'show map')",
    "routeMapShape",
    "routeMapWidth",
    "routeMapHeight",
    "OverlayStyle.backgroundRadius (square route-map corner radius)",
    "OverlayStyle.backgroundFadeOutEnabled / backgroundFadeOutAmount (route-map edge fade)",
    "OverlayStyle.borderEnabled / borderColor / borderOpacity / borderWidth (route-map border)",
    "routeMapColorMode",
    "routeMapGradientStart / Middle / End",
    "OverlayStyle.foregroundColor (solid route color)",
    "routeMapStartMarkerStyle",
    "routeMapEndMarkerStyle",
    "routeMapMarkerStyle (legacy quick-set)",
    "routeMapBackgroundStyle (single source of truth for map visibility)",
    "routeMapProvider (derived in OverlayRenderModel.routeMapLayout)",
    "OverlayElement.position.x / y",
    "OverlayElement.scale",
    "OverlayStyle.rotationDegrees",
    "OverlayStyle.backgroundOpacity (container fill alpha)",
    "OverlayStyle.shadowOpacity",
    "OverlayStyle.shadowRadius",
    "routeMapContainerPreset (template / test API; not in Inspector)",
    "routeMapMapOpacity",
    "routeMapLegendVisible / routeMapLegendMode (legacy migration only)",
    "routeMapStatsBar.visible / placement / inside / layoutMode / height / width / offsetX / offsetY / itemSpacing / backgroundOpacity / dividerOpacity / cornerRadius / slots"
  ],
  "modelGapsPhaseE": [],
  "modelGapsPhaseF": [
    "glowEnabled / glowColor / glowOpacity / glowRadius",
    "mapContrast / mapSaturation / mapBrightness / mapBlur",
    "routeLine width / opacity / dash / glow / shadow",
    "routeLine gradientMetric (byPace / byHeartRate / byPower / byElevation)",
    "pin / flag marker artwork",
    "per-marker size / border / label",
    "shadow color / shadow offsetX / shadow offsetY explicit (offsets exist, color is fixed)",
    "container blend mode",
    "Status Bar slot label override editing in inspector",
    "Status Bar typography overrides"
  ],
  "sharedStatsBarRenderer": {
    "preview": "PreviewCanvasView.SharedStatsBarContentView",
    "export": "SwiftUIOverlayVideoExporter via OverlaySharedRouteMapView",
    "mapSnapshotExport": "SwiftUIOverlayVideoExporter preloads MapKit NSImage snapshots from RouteMapSnapshotRequestBuilder and injects them into RouteMapOverlayView; failed snapshots fall back to the local grid.",
    "baseline": "Distance Timeline stats bar rendering behavior",
    "rules": [
      "Route Map and Distance Timeline use the same stats bar rendering pipeline.",
      "For left/right placement, stats bar renders as vertical stack and applies itemSpacing as row gap.",
      "For inside placement on Route Map, route content reserves bar lane so route lines do not draw under the bar."
    ]
  },
  "recommendedComponents": [
    "RouteMapOverlayDetailView",
    "RouteMapOverlayHeader",
    "InspectorDenseRow",
    "InspectorDenseSliderRow",
    "InspectorDenseSegmented",
    "InspectorDenseMenuLabel",
    "InspectorDenseSwatchStrip",
    "InspectorDenseAxisField",
    "InspectorAnchorGrid"
  ]
}
