{
  "name": "Numeric Overlay UI",
  "updated": "2026-06-02",
  "references": {
    "mockup": "./numeric-overlay.png",
    "relatedInspectorSpec": "../../panels/inspector/inspector-ui.md",
    "relatedStyleSpec": "../../system/app-ui.md"
  },
  "appliesToOverlayTypes": [
    "heartRate",
    "pace",
    "calories",
    "elapsedTime",
    "realTime",
    "distance",
    "elevation",
    "cadence",
    "power",
    "avgPace",
    "lapPace",
    "heartRateZone",
    "verticalOscillation",
    "groundContactTime",
    "strideLength",
    "verticalRatio",
    "groundContactBalance",
    "temperature",
    "grade"
  ],
  "excludedOverlayTypes": [
    "distanceTimeline",
    "elevationChart",
    "runningGauge",
    "routeMap"
  ],
  "intent": {
    "template": "dense reusable Inspector detail panel for numeric metric overlays",
    "density": "DaVinci-like compact parameter stack",
    "avoid": [
      "metric-specific one-off detail views",
      "large card rows",
      "loose vertical spacing",
      "fake unit menus",
      "enabled controls without model backing"
    ]
  },
  "tokens": {
    "reuse": "../../system/app-ui.spec.json",
    "numeric": {
      "sectionHeaderHeight": 30,
      "rowHeight": 32,
      "rowGap": 6,
      "sectionGap": 8,
      "labelColumnWidth": 112,
      "controlHeight": 30,
      "iconButtonSize": 28,
      "swatchSize": 22
    }
  },
  "header": {
    "title": "{overlay.label}",
    "pill": "Numeric Overlay",
    "valuePreview": "{formattedOverlayValue}",
    "actions": ["back", "delete"]
  },
  "renderStyle": {
    "mode": "minimalCleanOnly",
    "stylePresetPicker": false,
    "dividerControls": false,
    "legacyFieldsDecoded": ["OverlayStyle.textPreset", "OverlayStyle.dividerEnabled", "OverlayStyle.dividerColor", "OverlayStyle.dividerThickness", "OverlayStyle.dividerOpacity"]
  },
  "sections": [
    {
      "id": "content",
      "title": "Content",
      "controls": [
        { "id": "metric", "type": "dropdown", "value": "{metric}", "modelBacked": "future if metric can differ from OverlayElementType" },
        { "id": "units", "type": "dropdown", "value": "{unitOption}", "requiredWhen": "metric has more than one unit option" },
        { "id": "formatPreview", "type": "readout", "value": "{formattedOverlayValue}", "modelBacked": true }
      ]
    },
    {
      "id": "layout",
      "title": "Layout",
      "controls": [
        { "id": "position", "type": "numberPair", "labels": ["X", "Y"], "modelPaths": ["OverlayElement.position.x", "OverlayElement.position.y"] },
        { "id": "scale", "type": "slider", "modelPath": "OverlayElement.scale" },
        { "id": "minimumWidth", "type": "slider", "range": [0, 720], "modelPath": "OverlayStyle.numericMinWidth" },
        { "id": "minimumHeight", "type": "slider", "range": [0, 360], "modelPath": "OverlayStyle.numericMinHeight" },
        { "id": "opacity", "type": "slider", "range": [0, 1], "modelPath": "OverlayElement.opacity" }
      ]
    },
    {
      "id": "typography",
      "title": "Typography",
      "controls": [
        { "id": "font", "type": "dropdown", "modelPath": "OverlayStyle.fontName" },
        { "id": "fontSize", "type": "slider", "modelPath": "OverlayStyle.fontSize" },
        { "id": "fontWeight", "type": "segmented", "options": ["Regular", "Medium", "Semibold", "Bold"], "modelPath": "OverlayStyle.fontWeight" },
        { "id": "alignment", "type": "iconSegmented", "options": ["left", "center", "right"], "modelPath": "OverlayStyle.textAlignment" },
        { "id": "textColor", "type": "swatches", "modelPath": "OverlayStyle.valueColor" },
        { "id": "textOpacity", "type": "slider", "range": [0, 1], "modelPath": "OverlayStyle.valueOpacity" }
      ]
    },
    {
      "id": "label",
      "title": "Label",
      "controls": [
        { "id": "showLabel", "type": "toggle", "modelPath": "OverlayStyle.showLabel" },
        { "id": "labelText", "type": "textField", "modelPath": "OverlayStyle.customLabel" },
        { "id": "labelPosition", "type": "segmented", "options": ["top", "bottom", "leading", "trailing"], "modelPath": "OverlayStyle.labelPosition" },
        { "id": "labelAlignment", "type": "iconSegmented", "modelPath": "OverlayStyle.labelTextAlignment" },
        { "id": "labelColor", "type": "swatches", "modelPath": "OverlayStyle.labelColor" },
        { "id": "labelOpacity", "type": "slider", "range": [0, 1], "modelPath": "OverlayStyle.labelOpacity" },
        { "id": "labelFont", "type": "dropdown", "modelPath": "OverlayStyle.labelFontName" },
        { "id": "labelFontSize", "type": "slider", "modelPath": "OverlayStyle.labelFontSize" },
        { "id": "labelFontWeight", "type": "segmented", "modelPath": "OverlayStyle.labelFontWeight" },
        { "id": "labelSpacing", "type": "slider", "modelPath": "OverlayStyle.labelSpacing" }
      ]
    },
    {
      "id": "unit",
      "title": "Unit",
      "controls": [
        { "id": "showUnit", "type": "toggle", "modelPath": "OverlayStyle.showUnit" },
        { "id": "unitPosition", "type": "segmented", "options": ["top", "bottom", "leading", "trailing"], "modelPath": "OverlayStyle.unitPosition" },
        { "id": "unitAlignment", "type": "iconSegmented", "modelPath": "OverlayStyle.unitTextAlignment" },
        { "id": "unitColor", "type": "swatches", "modelPath": "OverlayStyle.unitColor" },
        { "id": "unitOpacity", "type": "slider", "range": [0, 1], "modelPath": "OverlayStyle.unitOpacity" },
        { "id": "unitFont", "type": "dropdown", "modelPath": "OverlayStyle.unitFontName" },
        { "id": "unitFontSize", "type": "slider", "modelPath": "OverlayStyle.unitFontSize" },
        { "id": "unitFontWeight", "type": "segmented", "modelPath": "OverlayStyle.unitFontWeight" },
        { "id": "unitSpacing", "type": "slider", "modelPath": "OverlayStyle.unitSpacing" }
      ]
    },
    {
      "id": "icon",
      "title": "Icon",
      "controls": [
        { "id": "showIcon", "type": "toggle", "modelPath": "OverlayStyle.iconEnabled" },
        { "id": "sfSymbol", "type": "textFieldOrMenu", "modelPath": "OverlayStyle.iconSystemName" },
        { "id": "iconPosition", "type": "segmented", "options": ["top", "bottom", "leading", "trailing"], "modelPath": "OverlayStyle.iconPosition" },
        { "id": "iconAlignment", "type": "iconSegmented", "modelPath": "OverlayStyle.iconTextAlignment" },
        { "id": "iconSize", "type": "slider", "range": [8, 96], "modelPath": "OverlayStyle.iconSize" },
        { "id": "iconColor", "type": "swatches", "modelPath": "OverlayStyle.iconColor" },
        { "id": "iconOpacity", "type": "slider", "range": [0, 1], "modelPath": "OverlayStyle.iconOpacity" },
        { "id": "iconSpacing", "type": "slider", "range": [0, 60], "modelPath": "OverlayStyle.iconSpacing" }
      ]
    },
    {
      "id": "background",
      "title": "Background",
      "controls": [
        { "id": "enableBackground", "type": "toggle", "modelPath": "OverlayStyle.backgroundEnabled" },
        { "id": "backgroundColor", "type": "swatches", "modelPath": "OverlayStyle.backgroundColor" },
        { "id": "backgroundOpacity", "type": "slider", "modelPath": "OverlayStyle.backgroundOpacity" },
        { "id": "backgroundRadius", "type": "slider", "modelPath": "OverlayStyle.backgroundRadius" },
        { "id": "backgroundPadding", "type": "numberPair", "labels": ["X", "Y"], "modelPaths": ["OverlayStyle.backgroundPaddingX", "OverlayStyle.backgroundPaddingY"] },
        { "id": "backgroundBlur", "type": "slider", "modelPath": "OverlayStyle.backgroundBlurRadius" }
      ]
    },
    {
      "id": "border",
      "title": "Border",
      "controls": [
        { "id": "enableBorder", "type": "toggle", "modelPath": "OverlayStyle.borderEnabled" },
        { "id": "borderColor", "type": "swatches", "modelPath": "OverlayStyle.borderColor" },
        { "id": "borderOpacity", "type": "slider", "modelPath": "OverlayStyle.borderOpacity" },
        { "id": "borderWidth", "type": "slider", "modelPath": "OverlayStyle.borderWidth" }
      ]
    },
    {
      "id": "effects",
      "title": "Effects",
      "controls": [
        { "id": "shadowToggle", "type": "toggle", "modelPath": "OverlayStyle.shadowEnabled" },
        { "id": "shadowColor", "type": "swatches", "modelPath": "OverlayStyle.shadowColor" },
        { "id": "shadowOpacity", "type": "slider", "modelPath": "OverlayStyle.shadowOpacity" },
        { "id": "shadowRadius", "type": "sliderOrField", "modelPath": "OverlayStyle.shadowRadius" },
        { "id": "shadowThickness", "type": "slider", "modelPath": "OverlayStyle.shadowThickness" },
        { "id": "shadowOffset", "type": "numberPair", "labels": ["X", "Y"], "modelPaths": ["OverlayStyle.shadowOffsetX", "OverlayStyle.shadowOffsetY"] },
        { "id": "glowToggle", "type": "toggle", "modelPath": "OverlayStyle.glowEnabled" },
        { "id": "glowColor", "type": "swatches", "modelPath": "OverlayStyle.glowColor" },
        { "id": "glowIntensity", "type": "slider", "modelPath": "OverlayStyle.glowIntensity" },
        { "id": "fadeOutToggle", "type": "toggle", "modelPath": "OverlayStyle.backgroundFadeOutEnabled" },
        { "id": "fadeAmount", "type": "slider", "modelPath": "OverlayStyle.backgroundFadeOutAmount" }
      ]
    }
  ],
  "unitOptionsByMetric": {
    "heartRate": ["bpm"],
    "pace": ["Metric (min/km)", "Imperial (min/mi)", "Rowing (min/500m)"],
    "distance": ["Metric (km)", "Imperial (mi)", "Meters (m)"],
    "elevation": ["Metric (m)", "Imperial (ft)"],
    "power": ["watts"],
    "cadence": ["spm"],
    "calories": ["kcal"],
    "elapsedTime": ["hh:mm:ss", "mm:ss", "seconds"],
    "realTime": ["12-hour", "24-hour"]
  },
  "metricSemantics": {
    "elapsedTime": "active elapsed time; subtract FIT timerPaused annotated spans from current FIT elapsed time, freezing while the playhead is inside a timer-paused span"
  },
  "modelBackedToday": [
    "type-derived metric",
    "formatted value preview",
    "SF Symbol icon name/position/alignment/size/color/opacity/spacing",
    "position x/y",
    "scale",
    "numeric minimum width/height",
    "font name",
    "font size",
    "font weight",
    "value/label/unit/icon color and opacity",
    "background opacity",
    "shadow opacity",
    "shadow radius"
  ],
  "modelGaps": [
    "metric reassignment independent of OverlayElementType",
    "rotation",
    "metric reassignment without creating a new OverlayElement"
  ],
  "renderingRules": [
    "Numeric Overlay 1.0 uses the Minimal Clean render path only; the Inspector does not expose a style preset picker.",
    "Divider rendering and divider controls are disabled for numeric overlays even when legacy divider fields decode as enabled.",
    "Numeric icons use SF Symbols via OverlayStyle.iconSystemName; each metric gets a default from OverlayElementType.defaultNumericIconSystemName and users can override it.",
    "Icon position and alignment follow the same top/bottom/left/right plus align/anchor pattern as Label and Unit.",
    "Unit text remains on one line and inline units grow the numeric overlay natural width instead of wrapping.",
    "numericMinWidth and numericMinHeight reserve additional frame space while keeping content pinned to the top-leading corner; zero preserves text-driven natural sizing.",
    "Numeric preview and SwiftUI export interpret position as the top-leading corner; value and label rows resolve to leading alignment, inline units and icons grow rightward while preserving anchor controls, and preview placement must avoid async content-size measurement; drag computes top-leading coordinates from canvas pointer location plus grab offset and preserves edge snapping through a top-leading snap/clamp path."
  ],
  "recommendedComponents": [
    "NumericOverlayDetailView",
    "InspectorDenseSection",
    "InspectorDenseRow",
    "InspectorDenseMenuRow",
    "InspectorDenseToggleRow",
    "InspectorDenseSliderRow",
    "InspectorDenseNumberPairRow",
    "InspectorUnitMenu",
    "InspectorAnchorGrid",
    "InspectorSwatchRow",
    "InspectorSegmentedIconControl"
  ]
}
