{
  "name": "Timeline UI",
  "updated": "2026-04-26",
  "references": {
    "mockup": "./timeline.png",
    "relatedStyleSpec": "./app-ui.md"
  },
  "currentEntryPoints": [
    "Sources/RunningOverlay/UI/TimelineView.swift",
    "Sources/RunningOverlay/Timeline/TimelineModel.swift"
  ],
  "intent": {
    "productTone": "dark professional video editor timeline with FIT alignment",
    "density": "compact",
    "primaryAccent": "blue",
    "avoid": [
      "large bright red playhead head",
      "separate Gaps Hidden status row",
      "pill-shaped adjacent clips",
      "heavy grid lines",
      "fake timeline content in empty projects"
    ]
  },
  "tokens": {
    "reuse": "./app-ui.spec.json",
    "timeline": {
      "fitGreen": "#49A862",
      "clipBlue": "#2F73D9",
      "playheadRed": "#E4525A",
      "trackBandA": "#15191D",
      "trackBandB": "#171C21",
      "labelColumnBackground": "#11161A",
      "spliceBorder": "#0B0F12",
      "dropTargetBorder": "#2F8CFF"
    }
  },
  "layout": [
    {
      "component": "TimelineHeader",
      "left": [
        { "type": "label", "text": "Preview" },
        { "type": "menuButton", "id": "previewTrackVisibility", "icon": "eye", "modelPath": "ProjectSettings.disabledPreviewTrackNames" }
      ],
      "right": [
        { "type": "iconButton", "id": "collapseGaps", "modelPath": "ProjectDocument.isTimelineCollapsed", "activeStyle": "accent.blue" },
        { "type": "label", "text": "Zoom" },
        { "type": "slider", "id": "zoom", "range": [0, 100], "modelPath": "ProjectDocument.timelineZoomSliderValue" },
        { "type": "valueLabel", "value": "{zoomLabel}", "example": "Fit" }
      ],
      "mustNotInclude": ["Gaps hidden status row", "large collapse status band"]
    },
    {
      "component": "TimelineRuler",
      "labels": ["-00:15", "27:10", "55:24", "1:01:23", "1:20:21", "1:26:52"],
      "hoverInfoPill": {
        "example": "55:24 • 9:39 AM • 10.61 km",
        "shape": "rounded pill with downward-pointing arrow on bottom edge whose tip aligns with the hovered ruler position"
      }
    },
    {
      "component": "TimelineLanes",
      "leftLabelColumn": ["FIT", "Layer 1", "Layer 2"],
      "tracks": [
        { "type": "fit", "color": "timeline.fitGreen", "draggable": true },
        { "type": "video", "color": "timeline.clipBlue", "clips": "multiple adjacent variable-width blocks" },
        { "type": "dropTarget", "label": "Drop to Layer 2", "visibleDuringDrag": true }
      ]
    },
    {
      "component": "TimelinePlayhead",
      "style": {
        "line": "thin muted red/coral, starting inside the ruler band and extending down to the bottom of the visible tracks",
        "head": "small downward-pointing triangle inside the ruler band, tip touching the vertical line",
        "avoid": [
          "large bright red arrow",
          "marker sticking out above the ruler",
          "rectangular or square block marker"
        ]
      }
    },
    {
      "component": "TimelineClipBlock",
      "selectedStyle": {
        "border": "2 px solid white",
        "fill": "timeline.clipBlue",
        "rules": ["white border replaces splice border on selected clip", "border must not overpower clip fill or playhead"]
      }
    }
  ],
  "preserveBehavior": [
    "per-track preview visibility menu",
    "collapse/expand gaps toggle",
    "nonlinear zoom slider and Fit label",
    "ruler seeking and hover data",
    "independent draggable FIT layer",
    "expanded-mode video clip horizontal drag",
    "collapsed mode hides no-video gaps",
    "collapsed mode disables existing video clip horizontal drag",
    "full-height playhead remains visible",
    "media drag/drop creates or moves clips",
    "one new-layer drop target during media drag",
    "empty project shows no fake timeline content"
  ],
  "interactions": {
    "rulerClickDrag": "seek playhead",
    "clipClick": "select clip",
    "clipDragExpanded": "move effective start time",
    "clipDragCollapsed": "disabled; selection still works",
    "fitTrackDrag": "change TimelineModel.fitStartTime",
    "zoom": "Command-scroll, pinch, shortcuts, and slider",
    "playback": "scroll timeline to keep playhead visible",
    "delete": "Delete/Forward Delete remove selected timeline clip when canvas has focus"
  },
  "recommendedComponents": [
    "TimelinePanel",
    "TimelineHeader",
    "TimelinePreviewTrackPicker",
    "TimelineTrackVisibilityMenu",
    "TimelineCollapseButton",
    "TimelineZoomControl",
    "TimelineRuler",
    "TimelineLabelColumn",
    "TimelineFitTrack",
    "TimelineClipBlock",
    "TimelinePlayhead",
    "TimelineDropTarget",
    "TimelineHoverInfoPill"
  ]
}

