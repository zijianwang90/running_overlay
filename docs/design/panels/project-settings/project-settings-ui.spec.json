{
  "name": "Project Settings, Heart Rate Zones, And Font Library",
  "lastUpdated": "2026-06-25",
  "surfaces": {
    "projectSettings": {
      "presentation": "dark macOS modal",
      "title": "Project Settings",
      "sizePoints": {
        "width": 640,
        "height": 620
      },
      "layout": {
        "videoControlWidth": 200,
        "openWeatherAPIKeyFieldWidth": 240,
        "rule": "Preserve comfortable separation between leading copy and trailing controls."
      },
      "sections": [
        {
          "title": "Video",
          "rows": [
            {
              "label": "Resolution",
              "control": "dropdown",
              "value": "1080p 16:9"
            },
            {
              "label": "Frame Rate",
              "control": "dropdown",
              "value": "30 fps"
            },
            {
              "label": "Layer Data FPS",
              "control": "dropdown",
              "value": "5 fps"
            }
          ]
        },
        {
          "title": "Typography",
          "rows": [
            {
              "label": "Font Library",
              "caption": "Choose fonts shown in overlay menus.",
              "control": "secondaryButton",
              "buttonLabel": "Manage..."
            }
          ]
        },
        {
          "title": "Physiology",
          "rows": [
            {
              "label": "Heart Rate Zones",
              "caption": "Configure HR and pace ranges for overlays.",
              "control": "secondaryButton",
              "buttonLabel": "Configure..."
            }
          ]
        },
        {
          "title": "Intervals",
          "rows": [
            {
              "label": "Interval Colors",
              "caption": "Set the colors used for Warm Up, Active, Rest, and Cool Down.",
              "control": "secondaryButton",
              "buttonLabel": "Configure..."
            }
          ]
        },
        {
          "title": "Weather",
          "rows": [
            {
              "label": "OpenWeather API Key",
              "caption": "Stored in macOS Keychain and used only for OpenWeather requests.",
              "control": "secureTextField",
              "placeholder": "API key",
              "persistence": "save to macOS Keychain whenever the field value changes",
              "separateSaveButton": false
            }
          ]
        }
      ],
      "footer": {
        "primaryAction": "Done",
        "alignment": "right"
      }
    },
    "heartRateZones": {
      "presentation": "dark macOS modal sheet",
      "title": "Heart Rate Zones",
      "subtitle": "Configure HR and pace ranges for each zone.",
      "mockup": "./heart-rate-zones.png",
      "functionalScope": [
        "Zone Count segmented control with 5 and 6",
        "Pace Unit segmented control with min/km and min/mile",
        "Threshold HR numeric field with bpm unit",
        "Threshold Pace field with selected pace unit",
        "Editable HR min/max and pace min/max fields for each visible zone",
        "Reset and Done footer actions"
      ],
      "excludedUntilImplemented": [
        "FIT zone import",
        "zone preview chart",
        "auto-fill toggle",
        "zone purpose/category editing",
        "timeline preview",
        "profile management"
      ],
      "sections": [
        {
          "title": "topSettings",
          "rows": [
            {
              "label": "Zone Count",
              "control": "segmented",
              "values": [
                "5",
                "6"
              ],
              "alignment": "trailing"
            },
            {
              "label": "Pace Unit",
              "control": "segmented",
              "values": [
                "min/km",
                "min/mile"
              ],
              "alignment": "trailing"
            }
          ]
        },
        {
          "title": "Threshold",
          "layout": "single grouped row with two aligned field groups",
          "fields": [
            {
              "label": "Threshold HR",
              "input": "numeric",
              "unit": "bpm",
              "example": "168"
            },
            {
              "label": "Threshold Pace",
              "input": "pace",
              "unit": "{paceUnit}",
              "example": "4:20"
            }
          ]
        },
        {
          "title": "Zones",
          "layout": "table grouped box",
          "columns": [
            "zone",
            "HR Range",
            "Pace Range"
          ],
          "row": {
            "leading": "colored dot plus Z label",
            "hrRange": "min field, dash, max field, bpm unit",
            "paceRange": "min field, dash, max field, selected pace unit",
            "separators": "subtle horizontal row separators",
            "floatingCards": false
          },
          "zoneColors": {
            "Z1": "blue",
            "Z2": "cyan",
            "Z3": "green",
            "Z4": "yellow",
            "Z5": "orange",
            "Z6": "red"
          }
        }
      ],
      "footer": {
        "secondaryAction": "Reset",
        "primaryAction": "Done"
      },
      "textLanguage": "English until localization pass"
    },
    "fontLibrary": {
      "presentation": "dark macOS modal sheet",
      "title": "Font Library",
      "subtitle": "Manage fonts shown in overlay menus.",
      "search": {
        "placeholder": "Search fonts",
        "filter": "localizedCaseInsensitiveContains"
      },
      "sections": [
        {
          "title": "Favorites",
          "purpose": "selected fonts shown first"
        },
        {
          "title": "All Fonts",
          "purpose": "searchable system font families"
        }
      ],
      "row": {
        "leadingControl": "checkbox",
        "primaryText": "font family name rendered in that family",
        "inlineDefaultAction": {
          "scope": "Favorites section only",
          "placement": "immediately after font family name",
          "currentDefaultState": {
            "label": "Default",
            "style": "blue compact pill",
            "visibility": "always"
          },
          "hoverState": {
            "label": "Default",
            "style": "gray compact button",
            "visibility": "on hover for non-default favorite rows"
          },
          "icons": "none",
          "layoutRule": "reserve inline space so rows do not shift when the hover action appears"
        },
        "trailingText": "numeric running preview rendered in the same family",
        "trailingExamples": [
          "5'42\"/km",
          "10.24 km",
          "4'58\"/km",
          "42.20 km"
        ],
        "numericPreviewAlignment": "right",
        "stableRowHeight": true
      },
      "footer": {
        "secondaryAction": "Restore Defaults",
        "selectedCountFormat": "%d fonts selected",
        "defaultSummaryFormat": "Default: %@",
        "combinedFooterExample": "4 fonts selected • Default: Menlo",
        "primaryAction": "Done"
      },
      "defaultFont": {
        "storage": "one favorite family name",
        "mustBeFavorite": true,
        "onRemoveCurrentDefault": "promote first remaining favorite",
        "emptyFavoritesFallback": "first fallback favorite",
        "restoreDefaults": "reset favorites and default to fallback favorites and clear active search"
      },
      "fallbackFavorites": [
        "Menlo",
        "PT Mono",
        "Monaco",
        "Andale Mono"
      ]
    }
  },
  "visualRules": {
    "theme": "dark utility editor",
    "titleAlignment": "center",
    "sectionTreatment": "header plus bordered grouped box",
    "rowTreatment": "stable height with subtle separators",
    "primaryAccent": "accent.blue",
    "secondaryControls": "raised dark control",
    "controlRadiusPx": "6-8"
  }
}
