{
  "name": "Preview UI",
  "updated": "2026-04-26",
  "references": {
    "mockup": "./preview.png",
    "relatedStyleSpec": "../../system/app-ui.md"
  },
  "currentSwiftUIEntryPoints": [
    "Sources/RunningOverlay/UI/PreviewCanvasView.swift",
    "Sources/RunningOverlay/UI/MainEditorView.swift"
  ],
  "intent": {
    "productTone": "central dark professional video preview and overlay editing surface",
    "primaryAccent": "blue",
    "density": "compact",
    "safeGuidesLocation": "inside Preview header, not beside Export",
    "avoid": [
      "preview timeline scrubber",
      "playback timecode text",
      "fullscreen control",
      "background checker toggle",
      "overlay visibility toggle",
      "export controls inside Preview"
    ]
  },
  "tokens": {
    "reuse": "../../system/app-ui.spec.json",
    "preview": {
      "headerHeightMin": 44,
      "headerHeightMax": 52,
      "playbackRowHeightMin": 44,
      "playbackRowHeightMax": 52,
      "iconButton": 30,
      "canvasHudRadius": 7,
      "guideStroke": "#2F8CFF",
      "guideOpacity": 0.42
    }
  },
  "layout": [
    {
      "component": "PreviewHeader",
      "left": [
        { "type": "title", "label": "Preview" },
        { "type": "metadata", "value": "{resolution} • {frameRate} fps", "fallback": "{resolution}" }
      ],
      "right": [
        { "type": "toggleButton", "id": "safeGuides", "icon": "viewfinder", "statePath": "ProjectDocument.showPreviewGuides", "activeStyle": "accent.blue" },
        { "type": "dropdown", "id": "fit", "label": "Fit", "modelBacked": "optional" }
      ],
      "mustNotInclude": ["fullscreen", "backgroundToggle", "overlayVisibility", "export"]
    },
    {
      "component": "PreviewCanvasWorkspace",
      "content": [
        { "type": "videoFrame", "sizing": "fitted project resolution" },
        { "type": "safeGuides", "visibleWhen": "ProjectDocument.showPreviewGuides == true", "hitTesting": false },
        { "type": "overlays", "coordinateSpace": "fitted canvas" },
        { "type": "selectionHandles", "visibleWhen": "overlay selected" },
        { "type": "hud", "label": "Guides On", "optional": true, "visibleWhen": "ProjectDocument.showPreviewGuides == true" }
      ]
    },
    {
      "component": "PreviewPlaybackRow",
      "height": "44-52",
      "centerCluster": [
        { "id": "previous", "icon": "backward.end", "action": "previous/step previous command" },
        { "id": "stop", "icon": "stop.fill", "action": "stop playback command" },
        { "id": "playPause", "icon": "play.fill or pause.fill", "action": "ProjectDocument.togglePlayback" },
        { "id": "next", "icon": "forward.end", "action": "next/step next command" }
      ],
      "right": [
        { "id": "playbackRate", "type": "dropdownButton", "label": "{playbackRate}x", "example": "1x" }
      ],
      "mustNotInclude": ["timecode", "time text", "scrubber", "progress bar", "timeline"]
    }
  ],
  "preserveBehavior": [
    "video preview playback",
    "media-pool source preview vs timeline playhead preview distinction",
    "overlay rendering on fitted canvas",
    "overlay selection by click",
    "overlay drag updates normalized position",
    "finish continuous edit at drag end",
    "empty canvas click clears media-pool preview and selection",
    "PreviewSafetyGuidesView remains non-interactive"
  ],
  "appToolbarChange": {
    "remove": "safe guides toggle from MainEditorView.toolbar",
    "keep": ["FIT import", "Videos import", "Export progress", "Export action"]
  },
  "interactions": {
    "safeGuides": "toggles ProjectDocument.showPreviewGuides",
    "fit": "controls preview zoom/fitting when model support exists; may be static initially",
    "playPause": "toggles playback",
    "rate": "shows current playback rate and later opens rate menu",
    "overlayClick": "selects overlay and opens Inspector detail state",
    "overlayDrag": "moves overlay in normalized fitted-canvas coordinates"
  },
  "recommendedComponents": [
    "PreviewPanel",
    "PreviewHeader",
    "PreviewMetadataLabel",
    "PreviewSafeGuidesButton",
    "PreviewFitMenu",
    "PreviewCanvasWorkspace",
    "PreviewCanvasHUD",
    "PreviewPlaybackBar",
    "PreviewPlaybackButton",
    "PreviewRateMenu"
  ]
}

