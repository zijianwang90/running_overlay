{
  "name": "Left Pool UI",
  "updated": "2026-04-29",
  "references": {
    "mockup": "./media-pool.png",
    "emptyMockup": "./media-pool-empty.png",
    "relatedStyleSpec": "../inspector/inspector-ui.md"
  },
  "intent": {
    "productTone": "dark professional desktop video-editing source, overlay, and template bin",
    "primaryAccent": "blue",
    "density": "compact",
    "avoid": [
      "generic bright system list styling",
      "oversized cards",
      "decorative backgrounds",
      "large empty black areas",
      "non-functional filter controls",
      "duplicating add-overlay tiles in the Inspector",
      "template management controls duplicated in Project Settings",
      "template rows with thumbnails, leading icons, trailing action buttons, or ellipsis controls"
    ]
  },
  "tokens": {
    "color": {
      "media.panel": "#15191D",
      "media.header": "#1B2025",
      "media.rowEven": "#1B2025",
      "media.rowOdd": "#171C21",
      "media.rowHover": "#222932",
      "media.rowSelected": "#263244",
      "media.rowSelectedBorder": "#2F8CFF",
      "media.menuBackground": "#1D2228",
      "media.menuHover": "#2F8CFF",
      "media.thumbnailBackground": "#101418",
      "text.primary": "#F3F6F8",
      "text.secondary": "#B6BEC7",
      "text.muted": "#7E8893",
      "border.subtle": "#2B3238",
      "accent.blue": "#2F8CFF",
      "danger.red": "#FF5A5F"
    },
    "markColor": {
      "red": "#FF5A5F",
      "orange": "#FF9342",
      "yellow": "#FFD166",
      "green": "#51C96B",
      "blue": "#2F8CFF",
      "purple": "#B657E8",
      "gray": "#9EA3AA"
    },
    "typography": {
      "headerTitle": { "size": 22, "weight": "semibold" },
      "filename": { "size": 13, "weight": "semibold" },
      "metadata": { "size": 11, "weight": "regular" },
      "status": { "size": 11, "weight": "medium" }
    },
    "size": {
      "rowHeight": 72,
      "thumbnailWidth": 42,
      "thumbnailHeight": 42,
      "toolbarIconButton": 30,
      "searchHeight": 30,
      "poolSwitchHeight": 32,
      "poolSwitchRadius": 8,
      "overlayTileMinHeight": 56,
      "overlayTileMaxHeight": 64,
      "overlayCategoryHeight": 24,
      "templateRowHeight": 30,
      "templateFooterButton": 32,
      "markDot": 9,
      "menuRadius": 8
    },
    "spacing": {
      "panelPaddingX": 12,
      "headerPaddingY": 10,
      "rowPaddingX": 12,
      "rowPaddingY": 8,
      "rowContentGap": 8
    }
  },
  "currentSwiftUIEntryPoints": [
    "Sources/RunningOverlay/UI/PoolPanelView.swift",
    "Sources/RunningOverlay/UI/MediaBrowserView.swift",
    "Sources/RunningOverlay/UI/OverlayPoolView.swift",
    "Sources/RunningOverlay/UI/TemplatePoolView.swift"
  ],
  "poolModes": [
    {
      "id": "media",
      "label": "Media Pool",
      "icon": "play.rectangle",
      "content": "MediaBrowserView"
    },
    {
      "id": "overlay",
      "label": "Overlay Pool",
      "icon": "square.stack.3d.up",
      "content": "OverlayPoolView"
    },
    {
      "id": "templates",
      "label": "Templates",
      "icon": "rectangle.stack",
      "content": "TemplatePoolView"
    }
  ],
  "poolSwitch": {
    "height": 32,
    "radius": 8,
    "placement": "top app toolbar, aligned to the left pane width",
    "selectedStyle": "accent blue fill or blue-accented dark fill",
    "unselectedStyle": "dark control fill, muted text, subtle border",
    "stateRule": "local UI state; do not persist in project files",
    "resizeRule": "switching pools must not reset mediaPoolWidth; resizing the left pane should keep the switch aligned to the left pane content width"
  },
  "preserveBehavior": [
    "drag/drop video import",
    "single row selection",
    "Command-click multi-selection",
    "Command+A select all visible media when active",
    "double-click source preview",
    "context menu match actions",
    "context menu mark actions",
    "context menu delete action",
    "tag filter menu",
    "alternating row backgrounds",
    "focus loss clears transient media-pool preview"
  ],
  "layout": [
    {
      "component": "PoolModeSwitch",
      "controls": [
        { "label": "Media Pool", "icon": "play.rectangle" },
        { "label": "Overlay Pool", "icon": "square.stack.3d.up" },
        { "label": "Templates", "icon": "rectangle.stack" }
      ]
    },
    {
      "component": "MediaPoolHeader",
      "content": {
        "title": "Media",
        "toolbarButtons": [
          { "id": "selectAllVisible", "icon": "checklist", "help": "Select All Visible Media" },
          { "id": "clearSelection", "icon": "xmark.circle", "help": "Clear Media Selection" },
          { "id": "filterMenu", "icon": "line.3.horizontal.decrease.circle", "help": "Filter by Mark" },
          { "id": "more", "icon": "chevron.down", "help": "Media options", "optional": true }
        ]
      }
    },
    {
      "component": "MediaPoolSearchAndFilter",
      "optional": true,
      "controls": [
        { "type": "searchField", "placeholder": "Search media", "implementationRule": "only show if it filters displayName" },
        { "type": "statusText", "value": "{visibleCount} clips" },
        { "type": "filterChip", "label": "All", "selected": true },
        { "type": "filterChip", "label": "Ready", "implementationRule": "only show if backed by real filter" },
        { "type": "filterChip", "label": "Aligned", "implementationRule": "only show if backed by real filter" }
      ]
    },
    {
      "component": "MediaPoolList",
      "rowHeight": 72,
      "rowComponent": "MediaPoolRow"
    }
  ],
  "row": {
    "content": [
      { "slot": "leading", "type": "thumbnailOrFileIcon", "optional": true },
      { "slot": "primary", "type": "filename", "modelPath": "MediaItem.displayName" },
      { "slot": "secondary", "type": "duration", "modelPath": "MediaItem.duration" },
      { "slot": "secondary", "type": "captureDate", "modelPath": "MediaItem.inferredStartDate" },
      { "slot": "trailing", "type": "alignmentStatusDot", "modelPath": "MediaItem.alignmentStatus", "help": "MediaItem.alignmentStatus.label" },
      { "slot": "mark", "type": "colorDotOrStripe", "optional": true, "help": "MediaTag.label" }
    ],
    "states": {
      "defaultEven": "media.rowEven",
      "defaultOdd": "media.rowOdd",
      "hover": "media.rowHover",
      "selected": "media.rowSelected with media.rowSelectedBorder accent",
      "multiSelected": "same as selected for each selected row"
    }
  },
  "contextMenu": {
    "items": [
      { "label": "Auto Match to Current Layer", "action": "project.matchMediaItemsToCurrentLayer(actionIDs)" },
      { "label": "Match to New Layer", "action": "project.matchMediaItemsToNewLayer(actionIDs)" },
      { "type": "separator" },
      {
        "label": "Mark",
        "submenu": [
          { "label": "Red", "mark": "red" },
          { "label": "Orange", "mark": "orange" },
          { "label": "Yellow", "mark": "yellow" },
          { "label": "Green", "mark": "green" },
          { "label": "Blue", "mark": "blue" },
          { "label": "Purple", "mark": "purple" },
          { "label": "Gray", "mark": "gray" },
          { "label": "Clear Mark", "mark": null }
        ]
      },
      { "type": "separator" },
      { "label": "Select All", "action": "selectedMediaIDs = visibleIDs" },
      { "label": "Delete from Media Pool", "action": "project.deleteMediaItems(actionIDs)" }
    ],
    "actionIDsRule": "if clicked item is already selected, apply to selectedMediaIDs; otherwise apply only to clicked item",
    "nativeMenuAcceptable": true
  },
  "emptyStates": {
    "noFitNoMedia": {
      "icon": "waveform.path.ecg",
      "title": "Import FIT",
      "secondaryText": "Start with running activity data",
      "primaryAction": "Import FIT",
      "stepIndicator": [
        { "label": "FIT", "state": "active" },
        { "label": "Videos", "state": "inactive" }
      ],
      "mutedHint": "Then import videos",
      "dropZone": "subtle dashed rounded rectangle; do not imply video drop is ready before FIT import"
    },
    "fitImportedNoMedia": {
      "icon": "video.badge.plus",
      "text": "Drop videos here",
      "secondaryText": "Import clips to match them with your running activity",
      "primaryAction": "Import Videos",
      "formatHint": "MP4, MOV",
      "stepIndicator": [
        { "label": "FIT", "state": "complete" },
        { "label": "Videos", "state": "active" }
      ],
      "dropZone": "subtle dashed rounded rectangle"
    },
    "filteredEmpty": {
      "icon": "line.3.horizontal.decrease.circle",
      "text": "No media with this mark"
    }
  },
  "overlayPool": {
    "purpose": "catalog of addable overlay modules; replaces Inspector Add Overlay section",
    "dataSourceRule": "reuse the OverlayTileInfo-style definitions currently backing Inspector add tiles",
    "header": {
      "title": "Overlay Pool",
      "status": "Add overlays",
      "avoid": "extra toolbar actions unless immediately useful"
    },
    "categories": [
      { "id": "metrics", "label": "Metrics" },
      { "id": "charts", "label": "Charts" },
      { "id": "route", "label": "Route" }
    ],
    "categoryControl": {
      "height": 24,
      "hitTargetRule": "full segment hit targets",
      "alignment": "centered in Overlay Pool content area",
      "selectedStyle": "accent blue",
      "unselectedStyle": "dark control fill with muted text"
    },
    "tileGrid": {
      "columnsAtDefaultWidth": 2,
      "fallbackColumnsBelowWidth": 1,
      "fallbackWidth": 320,
      "height": "56-64",
      "content": [
        "leading icon",
        "primary label",
        "secondary hint"
      ],
      "featuredStyle": "small blue accent line only; icons and primary labels stay text.primary"
    },
    "interaction": {
      "tap": "project.addOverlayElement(tile.type)",
      "afterAdd": "prefer selecting the new overlay and opening its detail Inspector"
    },
    "availability": {
      "beforeFitImport": "available",
      "missingFitChannelRule": "keep tile enabled and let preview use empty/default values",
      "hideRule": "do not hide overlay types based on current FIT data unless a future compatibility rule is explicit"
    }
  },
  "inspectorBoundary": {
    "outerStateContent": "Added Overlays only",
    "keptResponsibilities": [
      "visibility",
      "lock",
      "delete",
      "detail navigation",
      "overlay detail editing"
    ],
    "removedResponsibilities": [
      "Add Overlay catalog",
      "Metrics/Charts/Route overlay category tabs",
      "overlay add tiles"
    ]
  },
  "templatesPool": {
    "purpose": "single home for applying, saving, importing, exporting, and managing overlay templates",
    "replaces": "Overlay Templates controls in Project Settings",
    "header": {
      "title": "Templates",
      "status": "Apply layouts",
      "avoid": "header toolbar actions"
    },
    "sectionHeader": {
      "titles": ["Built-in Templates", "User Templates"],
      "foreground": "text.primary",
      "background": "media.header",
      "height": 40,
      "fullWidth": true,
      "bottomDivider": "border.subtle"
    },
    "rowStyle": {
      "height": 30,
      "content": ["template name only"],
      "noLeadingIcon": true,
      "noTrailingButton": true,
      "noEllipsis": true,
      "defaultBackground": "transparent or media.panel",
      "hoverBackground": "media.rowHover",
      "divider": "1px border.subtle"
    },
    "builtInTemplates": [
      {
        "id": "easyRun",
        "name": "Easy Run",
        "resource": "Sources/RunningOverlay/Resources/Templates/EasyRun.rotemplate",
        "elements": ["pace", "heartRate", "cadence", "routeMap", "distanceTimeline"],
        "actions": ["applyWithConfirmation"]
      },
      {
        "id": "intervalWorkout",
        "name": "Interval Workout",
        "resource": "Sources/RunningOverlay/Resources/Templates/IntervalWorkout.rotemplate",
        "elements": ["routeMap", "elapsedTime", "realTime", "weatherWidget", "intervalHUDBar", "intervalTimeline"],
        "actions": ["applyWithConfirmation"]
      },
      {
        "id": "race",
        "name": "Race",
        "resource": "Sources/RunningOverlay/Resources/Templates/Race.rotemplate",
        "elements": ["pace", "heartRate", "cadence", "routeMap", "distanceTimeline", "elapsedTime", "realTime", "power", "weatherWidget", "zoneEdgeBar"],
        "actions": ["applyWithConfirmation"]
      }
    ],
    "userTemplates": {
      "dataSource": "ProjectDocument.overlayTemplates",
      "emptyRow": "No saved templates yet",
      "rowClick": "applyWithConfirmation",
      "contextMenu": [
        "Rename",
        "Duplicate",
        "Update Template",
        "Export...",
        "Delete"
      ],
      "updateRule": "confirm before overwriting selected user template contents with the current overlay setup",
      "deleteRule": "confirm before deleting",
      "exportRule": "export selected template as standalone shareable template file"
    },
    "applyRule": {
      "behavior": "clear current overlay layout and replace with selected template",
      "confirmationRequired": true,
      "confirmationCopyExample": "Replace current overlays with \"Race\"?",
      "undo": "ProjectDocument registers undo point",
      "selectionAfterApply": "clear selection"
    },
    "footer": {
      "layout": "sticky bottom horizontal row",
      "importButton": {
        "placement": "left",
        "style": "secondary icon-only square",
        "size": 32,
        "icon": "tray.and.arrow.down",
        "help": "Import Template",
        "action": "open template file picker; import into user template library without applying"
      },
      "saveButton": {
        "placement": "right",
        "style": "primary blue",
        "height": 32,
        "label": "Save Current as Template",
        "icon": "plus",
        "action": "save current overlay layout as a user template",
        "disabledRule": "disabled when current overlay layout has no elements"
      }
    },
    "blankSpaceContextMenu": [],
    "nameCollisionRule": "generate a readable copy name rather than overwriting without confirmation"
  },
  "recommendedComponents": [
    "PoolPanelView",
    "PoolModeSwitch",
    "MediaPoolPanel",
    "MediaPoolHeader",
    "MediaPoolToolbarButton",
    "MediaPoolSearchField",
    "MediaPoolFilterStrip",
    "MediaPoolRow",
    "MediaStatusPill",
    "MediaTagDot",
    "MediaPoolEmptyState",
    "OverlayPoolView",
    "OverlayPoolHeader",
    "OverlayCategorySwitch",
    "OverlayAddTile",
    "TemplatePoolView",
    "TemplatePoolSection",
    "TemplatePoolRow",
    "TemplatePoolFooter",
    "TemplateReplaceConfirmation"
  ],
  "openQuestions": [
    "Should search be added now or deferred?",
    "Should Ready and Aligned filter chips be real filters or deferred?",
    "Should rows show real thumbnails or icon wells?",
    "Should tag color be shown as a dot, left stripe, or both?"
  ]
}
